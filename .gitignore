# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like PHX://assets are installed.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Environment files
.env
.env.local

# In case you use Node.js/Esbuild/Tailwind
/assets/node_modules/

# Vendored JS plugins
/assets/vendor/heroicons.js

# macOS
.DS_Store

# Windows
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Erlang crash dumps
erl_crash.dump

# Playwright
/test-results/
/playwright-report/
.playwright-mcp/
/node_modules/

# Local uploads
/priv/uploads/

# Generated reports
/docs/playwright-report/
/docs/screenshots/

# Git worktrees
.worktrees/

# Claude Code local overrides
.claude.local.md

# Superpowers brainstorm mockups
.superpowers/
