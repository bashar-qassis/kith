# ============================================================
# Core
# ============================================================
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
DATABASE_URL=ecto://postgres:postgres@localhost/kith_dev
KITH_HOSTNAME=localhost
KITH_MODE=web
PORT=4000
POOL_SIZE=10

# ============================================================
# Auth
# ============================================================
DISABLE_SIGNUP=false
SIGNUP_DOUBLE_OPTIN=true

# ============================================================
# Email
# ============================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@localhost

# ============================================================
# Storage
# ============================================================
STORAGE_PATH=/app/uploads
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
MAX_UPLOAD_SIZE_KB=5120
MAX_STORAGE_SIZE_MB=1024

# ============================================================
# Integrations
# ============================================================
IMMICH_BASE_URL=
IMMICH_API_KEY=
IMMICH_SYNC_INTERVAL_HOURS=24
LOCATION_IQ_API_KEY=
ENABLE_GEOLOCATION=false

# ============================================================
# Rate Limiting
# ============================================================
# Backend: "ets" (single-node, no dependencies) or "redis" (multi-node)
RATE_LIMIT_BACKEND=ets
REDIS_URL=

# ============================================================
# Networking
# ============================================================
TRUSTED_PROXIES=127.0.0.1/8

# ============================================================
# Observability
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
METRICS_TOKEN=
