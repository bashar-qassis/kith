# ============================================
# Kith Environment Configuration
# ============================================
# Copy to .env and fill in all required values:
#   cp .env.example .env
#   chmod 600 .env
#
# Generate secrets with: mix phx.gen.secret
# Or: openssl rand -base64 64

# ============================================================
# Core — REQUIRED (no defaults)
# ============================================================
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
DATABASE_URL=ecto://kith:change_me@postgres:5432/kith_prod
AUTH_TOKEN_SALT=generate-with-mix-phx-gen-secret
CLOAK_KEY=generate-32-byte-base64-key

# ============================================================
# Hostname
# ============================================================
# Set to your domain for automatic TLS via Let's Encrypt.
# Use "localhost" for local/dev (HTTP only).
KITH_HOSTNAME=localhost

# ============================================================
# Database — for PostgreSQL container init
# ============================================================
# These are read by the postgres Docker container, separate from DATABASE_URL.
POSTGRES_USER=kith
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kith_prod
# Port the Elixir app uses to connect to PostgreSQL (default: 5432)
DB_PORT=5432
# Host port Docker maps for PostgreSQL (only affects docker-compose.dev.yml)
# DOCKER_DB_PORT=5432
POOL_SIZE=10
# DATABASE_SSL=false

# ============================================================
# Runtime Mode
# ============================================================
# "web" = full Phoenix app; "worker" = Oban only (no HTTP)
# Normally set per-service in docker-compose.prod.yml, not here.
# KITH_MODE=web
# PORT=4000

# ============================================================
# Auth / OAuth (optional)
# ============================================================
TOTP_ISSUER=Kith
DISABLE_SIGNUP=false
SIGNUP_DOUBLE_OPTIN=true
# Require users to accept Terms of Service during registration
REQUIRE_TOS_ACCEPTANCE=false
# GitHub OAuth — leave blank to disable
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth — leave blank to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Email
# ============================================================
# Adapter: smtp (default), mailgun, ses, postmark
MAILER_ADAPTER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@example.com
# Mailgun (if MAILER_ADAPTER=mailgun)
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# Postmark (if MAILER_ADAPTER=postmark)
# POSTMARK_API_KEY=

# ============================================================
# File Storage
# ============================================================
# Local disk (default): files stored at STORAGE_PATH
STORAGE_PATH=/app/uploads
MAX_UPLOAD_SIZE_KB=5120
MAX_STORAGE_SIZE_MB=0
# S3 (optional): set AWS_S3_BUCKET to enable; local disk is ignored
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=

# ============================================================
# Integrations (optional)
# ============================================================
IMMICH_ENABLED=false
IMMICH_BASE_URL=
IMMICH_API_KEY=
IMMICH_SYNC_INTERVAL_HOURS=24
ENABLE_GEOLOCATION=false
LOCATION_IQ_API_KEY=

# ============================================================
# Rate Limiting
# ============================================================
# "ets" = single-node (default); "redis" = shared across replicas
RATE_LIMIT_BACKEND=ets
REDIS_URL=

# ============================================================
# Networking
# ============================================================
# Docker default bridge network; adjust if using custom networks
TRUSTED_PROXIES=172.16.0.0/12

# ============================================================
# Observability (optional)
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Required in production for /metrics endpoint access
METRICS_TOKEN=generate-a-random-token
