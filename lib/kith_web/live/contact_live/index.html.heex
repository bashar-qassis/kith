<Layouts.app
  flash={@flash}
  current_scope={@current_scope}
  current_path={@current_path}
  pending_duplicates_count={@pending_duplicates_count}
>
  <div class="space-y-6">
    <%!-- Header --%>
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-[var(--color-text-primary)] tracking-tight">
        Contacts
      </h1>
      <div class="flex items-center gap-3">
        <%= if can?(assigns, :create, :contact) do %>
          <UI.button size="sm" navigate={~p"/contacts/new"}>
            <.icon name="hero-plus" class="size-4" /> New Contact
          </UI.button>
        <% end %>
      </div>
    </div>

    <%!-- Secondary navigation --%>
    <nav class="flex items-center gap-1 border-b border-[var(--color-border)]">
      <.link
        navigate={~p"/contacts"}
        class={[
          "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 transition-colors",
          if(@live_action == :index,
            do: "border-[var(--color-accent)] text-[var(--color-accent)]",
            else:
              "border-transparent text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border)]"
          )
        ]}
      >
        <.icon name="hero-user-group" class="size-4" /> All
      </.link>
      <.link
        navigate={~p"/contacts/archived"}
        class={[
          "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 transition-colors",
          if(@live_action == :archived,
            do: "border-[var(--color-accent)] text-[var(--color-accent)]",
            else:
              "border-transparent text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border)]"
          )
        ]}
      >
        <.icon name="hero-archive-box" class="size-4" /> Archived
      </.link>
      <.link
        navigate={~p"/contacts/duplicates"}
        class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border)] transition-colors"
      >
        <.icon name="hero-document-duplicate" class="size-4" /> Duplicates
        <span
          :if={@pending_duplicates_count > 0}
          class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 rounded-[var(--radius-full)] bg-[var(--color-warning-subtle)] text-[var(--color-warning)] text-xs font-medium"
        >
          {@pending_duplicates_count}
        </span>
      </.link>
      <.link
        navigate={~p"/contacts/trash"}
        class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border)] transition-colors"
      >
        <.icon name="hero-trash" class="size-4" /> Trash
      </.link>
    </nav>

    <%!-- Search and filters --%>
    <div class="flex flex-col sm:flex-row gap-4">
      <div class="flex-1">
        <form phx-change="search" phx-submit="search">
          <div class="relative">
            <.icon
              name="hero-magnifying-glass"
              class="absolute start-3 top-1/2 -translate-y-1/2 size-4 text-[var(--color-text-tertiary)]"
            />
            <input
              type="text"
              name="search"
              value={@search}
              placeholder="Search contacts..."
              phx-debounce="300"
              class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-elevated)] ps-10 pe-3 py-2 text-sm text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] focus:border-[var(--color-border-focus)] focus:outline-none focus:ring-2 focus:ring-[var(--color-border-focus)]/20 transition-colors duration-150"
            />
          </div>
        </form>
      </div>

      <div class="flex items-center gap-3 flex-wrap">
        <select
          name="sort"
          phx-change="sort"
          class="rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-3 py-2 text-sm text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] focus:outline-none focus:ring-2 focus:ring-[var(--color-border-focus)]/20"
        >
          <option value="name_asc" selected={@sort == "name_asc"}>Name A-Z</option>
          <option value="name_desc" selected={@sort == "name_desc"}>Name Z-A</option>
          <option value="recently_added" selected={@sort == "recently_added"}>
            Recently Added
          </option>
          <option value="recently_contacted" selected={@sort == "recently_contacted"}>
            Recently Contacted
          </option>
        </select>

        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input
            type="checkbox"
            checked={@show_deceased}
            phx-click="toggle-deceased"
            class="size-4 rounded-[var(--radius-sm)] border border-[var(--color-border)] accent-[var(--color-accent)] cursor-pointer"
          />
          <span class="text-sm text-[var(--color-text-secondary)]">Include deceased</span>
        </label>

        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input
            type="checkbox"
            checked={@show_favorites_only}
            phx-click="toggle-favorites"
            class="size-4 rounded-[var(--radius-sm)] border border-[var(--color-border)] accent-[var(--color-accent)] cursor-pointer"
          />
          <span class="text-sm text-[var(--color-text-secondary)]">Favorites</span>
        </label>
      </div>
    </div>

    <%!-- Tag filter --%>
    <%= if @tags != [] do %>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-medium uppercase tracking-wider text-[var(--color-text-tertiary)]">
          Tags:
        </span>
        <%= for tag <- @tags do %>
          <label class="cursor-pointer">
            <input
              type="checkbox"
              value={tag.id}
              checked={to_string(tag.id) in @selected_tag_ids}
              phx-click="filter-tags"
              phx-value-tag_ids={
                toggle_tag_id(@selected_tag_ids, to_string(tag.id)) |> Jason.encode!()
              }
              class="hidden"
            />
            <span class={[
              "inline-flex items-center rounded-[var(--radius-full)] px-2.5 py-1 text-xs font-medium transition-colors duration-150",
              if(to_string(tag.id) in @selected_tag_ids,
                do: "bg-[var(--color-accent)] text-[var(--color-accent-foreground)]",
                else:
                  "border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)]/50 hover:text-[var(--color-accent)]"
              )
            ]}>
              {tag.name}
            </span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%!-- Bulk action bar (Linear-style floating) --%>
    <%= if MapSet.size(@selected_ids) > 0 and can?(assigns, :update, :contact) do %>
      <div class="sticky bottom-4 z-30 mx-auto max-w-fit animate-in slide-in-from-bottom-4 fade-in duration-200">
        <div class="flex items-center gap-2 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-overlay)] shadow-[var(--shadow-dropdown)] px-4 py-2.5">
          <span class="text-sm font-medium text-[var(--color-text-primary)]">
            {MapSet.size(@selected_ids)} selected
          </span>
          <div class="w-px h-5 bg-[var(--color-border)]" />
          <button
            phx-click="bulk-favorite"
            class="inline-flex items-center gap-1.5 rounded-[var(--radius-md)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-sunken)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer"
          >
            <.icon name="hero-star" class="size-3.5" /> Favorite
          </button>
          <button
            phx-click="bulk-archive"
            class="inline-flex items-center gap-1.5 rounded-[var(--radius-md)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-sunken)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer"
          >
            <.icon name="hero-archive-box" class="size-3.5" /> Archive
          </button>
          <button
            phx-click="bulk-delete"
            class="inline-flex items-center gap-1.5 rounded-[var(--radius-md)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-error)] hover:bg-[var(--color-error-subtle)] transition-colors cursor-pointer"
            data-confirm="Move selected contacts to trash?"
          >
            <.icon name="hero-trash" class="size-3.5" /> Delete
          </button>

          <%!-- Bulk tag dropdowns --%>
          <%= if @tags != [] do %>
            <div class="w-px h-5 bg-[var(--color-border)]" />
            <div class="relative inline-block" x-data="{ open: false }">
              <button
                x-on:click="open = !open"
                class="inline-flex items-center gap-1.5 rounded-[var(--radius-md)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-sunken)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer"
              >
                <.icon name="hero-tag" class="size-3.5" /> Add Tag
              </button>
              <div
                x-show="open"
                x-on:click.outside="open = false"
                x-transition
                class="absolute bottom-full mb-2 start-0 z-50 min-w-[10rem] rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-overlay)] shadow-[var(--shadow-dropdown)] py-1"
                style="display: none;"
              >
                <%= for tag <- @tags do %>
                  <button
                    phx-click="bulk-assign-tag"
                    phx-value-tag_id={tag.id}
                    class="block w-full text-start px-3 py-1.5 text-sm text-[var(--color-text-primary)] hover:bg-[var(--color-surface-sunken)] transition-colors"
                    x-on:click="open = false"
                  >
                    {tag.name}
                  </button>
                <% end %>
              </div>
            </div>
            <div class="relative inline-block" x-data="{ open: false }">
              <button
                x-on:click="open = !open"
                class="inline-flex items-center gap-1.5 rounded-[var(--radius-md)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-sunken)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer"
              >
                <.icon name="hero-tag" class="size-3.5" /> Remove Tag
              </button>
              <div
                x-show="open"
                x-on:click.outside="open = false"
                x-transition
                class="absolute bottom-full mb-2 start-0 z-50 min-w-[10rem] rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-overlay)] shadow-[var(--shadow-dropdown)] py-1"
                style="display: none;"
              >
                <%= for tag <- @tags do %>
                  <button
                    phx-click="bulk-remove-tag"
                    phx-value-tag_id={tag.id}
                    class="block w-full text-start px-3 py-1.5 text-sm text-[var(--color-text-primary)] hover:bg-[var(--color-surface-sunken)] transition-colors"
                    x-on:click="open = false"
                  >
                    {tag.name}
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%!-- Contact table --%>
    <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-elevated)] overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[var(--color-border)]">
            <%= if can?(assigns, :update, :contact) do %>
              <th class="w-10 px-4 py-3">
                <input
                  type="checkbox"
                  class="size-4 rounded-[var(--radius-sm)] border border-[var(--color-border)] accent-[var(--color-accent)] cursor-pointer"
                  phx-click="select-all"
                  checked={
                    MapSet.size(@selected_ids) > 0 and
                      MapSet.size(@selected_ids) == length(@contacts)
                  }
                />
              </th>
            <% end %>
            <th class="w-12 px-4 py-3"></th>
            <th class="px-4 py-3 text-start text-xs font-medium uppercase tracking-wider text-[var(--color-text-tertiary)]">
              Name
            </th>
            <th class="hidden md:table-cell px-4 py-3 text-start text-xs font-medium uppercase tracking-wider text-[var(--color-text-tertiary)]">
              Company
            </th>
            <th class="hidden md:table-cell px-4 py-3 text-start text-xs font-medium uppercase tracking-wider text-[var(--color-text-tertiary)]">
              Tags
            </th>
            <th class="hidden lg:table-cell px-4 py-3 text-start text-xs font-medium uppercase tracking-wider text-[var(--color-text-tertiary)]">
              Last Contacted
            </th>
            <th class="w-10 px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          <%= if @contacts == [] do %>
            <tr>
              <td colspan="7" class="py-16">
                <KithUI.empty_state
                  icon="hero-user-group"
                  title="No contacts found"
                  message={
                    if @search != "",
                      do: "Try a different search term.",
                      else: "Add your first contact to get started."
                  }
                >
                  <:actions>
                    <UI.button :if={@search == ""} size="sm" navigate={~p"/contacts/new"}>
                      Add contact
                    </UI.button>
                  </:actions>
                </KithUI.empty_state>
              </td>
            </tr>
          <% end %>
          <%= for contact <- @contacts do %>
            <tr class={[
              "border-b border-[var(--color-border-subtle)] hover:bg-[var(--color-surface-sunken)] transition-colors duration-150",
              contact.is_archived && "opacity-60"
            ]}>
              <%= if can?(assigns, :update, :contact) do %>
                <td class="px-4 py-3">
                  <input
                    type="checkbox"
                    class="size-4 rounded-[var(--radius-sm)] border border-[var(--color-border)] accent-[var(--color-accent)] cursor-pointer"
                    checked={MapSet.member?(@selected_ids, contact.id)}
                    phx-click="toggle-select"
                    phx-value-id={contact.id}
                  />
                </td>
              <% end %>
              <td class="px-4 py-3">
                <.link navigate={~p"/contacts/#{contact.id}"}>
                  <KithUI.avatar
                    name={contact.display_name}
                    src={contact_photo_url(contact)}
                    size={:sm}
                  />
                </.link>
              </td>
              <td class="px-4 py-3">
                <.link
                  navigate={~p"/contacts/#{contact.id}"}
                  class="font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
                >
                  {contact.display_name}
                </.link>
                <UI.badge :if={contact.is_archived} variant="default" class="ms-1.5">
                  archived
                </UI.badge>
                <UI.badge :if={contact.deceased} variant="default" class="ms-1.5">
                  deceased
                </UI.badge>
              </td>
              <td class="hidden md:table-cell px-4 py-3 text-[var(--color-text-secondary)]">
                {contact.company}
              </td>
              <td class="hidden md:table-cell px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  <KithUI.tag_badge :for={tag <- contact.tags || []} tag={tag} />
                </div>
              </td>
              <td class="hidden lg:table-cell px-4 py-3 text-sm">
                <KithUI.relative_time
                  :if={contact.last_talked_to}
                  datetime={contact.last_talked_to}
                />
              </td>
              <td class="px-4 py-3">
                <button
                  phx-click="toggle-favorite"
                  phx-value-id={contact.id}
                  class="rounded-[var(--radius-md)] p-1 text-[var(--color-text-tertiary)] hover:text-[var(--color-warning)] transition-colors cursor-pointer"
                  title={if contact.favorite, do: "Unfavorite", else: "Favorite"}
                >
                  <.icon
                    name={if contact.favorite, do: "hero-star-solid", else: "hero-star"}
                    class={["size-5", contact.favorite && "text-[var(--color-warning)]"]}
                  />
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%!-- Load more --%>
    <div :if={@meta && @meta.has_next_page?} class="flex justify-center">
      <UI.button variant="secondary" size="sm" phx-click="load-more">
        Load more
      </UI.button>
    </div>
  </div>
</Layouts.app>
